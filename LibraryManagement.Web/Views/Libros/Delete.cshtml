@model LibraryManagement.Web.Models.LibroViewModel

<h2>Eliminar Libro</h2>

<h3>żEstá seguro que desea eliminar este libro?</h3>

<div>
    <h4>Libro</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Id</dt>
        <dd>@Model.Id</dd>

        <dt>Título</dt>
        <dd>@Model.Titulo</dd>

        <dt>Ańo</dt>
        <dd>@Model.Anio</dd>

        <dt>Género</dt>
        <dd>@Model.Genero</dd>

        <dt>Número de Páginas</dt>
        <dd>@Model.NumeroPaginas</dd>

        <dt>AutorId</dt>
        <dd>@Model.AutorId</dd>

        <dt>Fecha de Publicación</dt>
        <dd>@(Model.FechaPublicacion.HasValue ? Model.FechaPublicacion.Value.ToString("yyyy-MM-dd") : "-")</dd>
    </dl>

    @using (Html.BeginForm("Delete", "Libros", FormMethod.Post)) {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.Id)
        <input type="submit" value="Eliminar" class="btn btn-danger" />
        @Html.ActionLink("Volver a la lista", "Index", null, new { @class = "btn btn-default" })
    }
</div>
